; F104: Set Date and Time
;   In: DE = pointer to 4-byte DAT in TPA [days_lo, days_hi, hour, min]
;   Out: A = 0
;   Clobbers: AF, BC, DE, HL
; @proc bf_f104
; @param %dat:u16   de
; @param %func:u8   c
; @out   a
; @out   hl
; @clobbers af,bc,de,hl
; @end
bf_f104:
    pop de
    pop bc
    ; Read 4 bytes from TPA at DE
    push de
    call read_user_byte(de) preserving %func    ; A = days_lo
    ld (scb_date), a
    pop de
    inc de
    push de
    call read_user_byte(de) preserving %func    ; A = days_hi
    ld (scb_date+1), a
    pop de
    inc de
    ; Read BCD hour → binary, multiply by 60
    push de
    call read_user_byte(de) preserving %func    ; A = BCD hour
    call bcd_to_bin                              ; A = binary hour
    pop de
    inc de                         ; DE = minute pointer
    push de                        ; preserve across the hour*60 math
    ld l, a
    ld h, 0                        ; HL = hour
    add hl, hl
    add hl, hl                     ; HL = hour * 4
    push hl
    add hl, hl
    add hl, hl
    add hl, hl                     ; HL = hour * 32
    add hl, hl                     ; HL = hour * 64
    pop de                         ; DE = hour * 4
    or a
    sbc hl, de                     ; HL = hour * 60
    pop de                         ; DE = minute pointer (restored)
    push hl                        ; save hour * 60
    ; Read BCD min → binary, add to hour*60
    call read_user_byte(de) preserving %func    ; A = BCD min
    call bcd_to_bin                              ; A = binary min
    ld e, a
    ld d, 0
    pop hl                         ; HL = hour * 60
    add hl, de                     ; HL = minutes since midnight
    ld (scb_minute), hl
    xor a
    ld (scb_sec), a
    ld l, a
    ld h, a
    jp bdos_ret


; F105: Get Date and Time
;   Out: DMA[0..4] = days_lo, days_hi, hour, min, sec (BCD)
;        A = BCD sec, HL = scb_date
;   Clobbers: AF, BC, DE, HL
; @proc bf_f105
; @param %param:u16 de
; @param %func:u8   c
; @out   a
; @out   hl
; @clobbers af,bc,de,hl
; @end
bf_f105:
    pop de
    pop bc
    ld de, (bdos_dma)
    ld a, (scb_date)
    call write_user_byte(a, de) preserving %func ; DMA[0] = days_lo
    inc de
    ld a, (scb_date+1)
    call write_user_byte(a, de) preserving %func ; DMA[1] = days_hi
    inc de
    ; minutes → BCD hour + BCD minute
    ld hl, (scb_minute)
    call div_hl_60                  ; A = hour, L = minute
    ld b, l                         ; B = minute (bin_to_bcd preserves BC)
    call bin_to_bcd                 ; A = BCD hour
    call write_user_byte(a, de) preserving %func ; DMA[2] = BCD hour
    inc de
    ld a, b                         ; A = minute
    call bin_to_bcd                 ; A = BCD minute
    call write_user_byte(a, de) preserving %func ; DMA[3] = BCD minute
    inc de
    ld a, (scb_sec)
    call bin_to_bcd                 ; A = BCD second
    ld b, a                         ; save BCD sec (write_user_byte may clobber A)
    call write_user_byte(a, de) preserving %func ; DMA[4] = BCD sec
    ld hl, (scb_date)
    ld a, b                         ; A = BCD sec (return value)
    jp bdos_ret


; ------------------------------------------------------------------
; bcd_to_bin — convert BCD byte to binary
;
; @proc bcd_to_bin
; @param %bcd:u8  a                ; BCD value (e.g. 0x23 = 23)
; @out   a                         ; binary value
; @clobbers af
; @end
bcd_to_bin:
    push bc
    ld b, a
    and 0x0F
    ld c, a                         ; C = units
    ld a, b
    rrca
    rrca
    rrca
    rrca
    and 0x0F                        ; A = tens
    ld b, a
    add a, a
    add a, a
    add a, a                        ; tens * 8
    add a, b
    add a, b                        ; tens * 10
    add a, c                        ; + units
    pop bc
    ret


; ------------------------------------------------------------------
; bin_to_bcd — convert binary byte to BCD
;
; @proc bin_to_bcd
; @param %val:u8  a                ; binary 0-99
; @out   a                         ; BCD encoded
; @clobbers af
; @end
bin_to_bcd:
    push bc
    ld b, 0
.lp:
    cp 10
    jr c, .done
    sub 10
    inc b
    jr .lp
.done:
    ld c, a                         ; C = units
    ld a, b                         ; A = tens
    add a, a
    add a, a
    add a, a
    add a, a                        ; tens << 4
    or c                            ; (tens << 4) | units
    pop bc
    ret


; ------------------------------------------------------------------
; div_hl_60 — divide HL by 60
;
; @proc div_hl_60
; @param %dividend:u16  hl         ; 0-1439
; @out   a                         ; quotient (0-23)
; @out   l                         ; remainder (0-59)
; @clobbers af,h
; @end
div_hl_60:
    push bc
    xor a
.lp:
    ld b, a
    ld a, h
    or a
    jr nz, .sub
    ld a, l
    cp 60
    jr c, .done
.sub:
    ld a, l
    sub 60
    ld l, a
    jr nc, .nb
    dec h
.nb:
    ld a, b
    inc a
    jr .lp
.done:
    ld a, b
    pop bc
    ret


; F106: Set Default Password (stub)
;   Out: A = 0
;   Clobbers: AF, DE, BC, HL
; @proc bf_f106
; @param %param:u16 de
; @param %func:u8   c
; @out   a
; @out   hl
; @clobbers af,bc,de,hl
; @end
bf_f106:
    pop de
    pop bc
    xor a
    ld l, a
    ld h, a
    jp bdos_ret


; F107: Get Serial Number
;   Out: 6 bytes "CPM31\0" written to DMA
;        A = 0
;   Clobbers: AF, BC, DE, HL
; @proc bf_f107
; @param %param:u16 de
; @param %func:u8   c
; @out   a
; @out   hl
; @clobbers af,bc,de,hl
; @end
bf_f107:
    pop de
    pop bc
    ld de, (bdos_dma)
    ld a, 'C'
    call write_user_byte(a, de) preserving %func
    inc de
    ld a, 'P'
    call write_user_byte(a, de) preserving %func
    inc de
    ld a, 'M'
    call write_user_byte(a, de) preserving %func
    inc de
    ld a, '3'
    call write_user_byte(a, de) preserving %func
    inc de
    ld a, '1'
    call write_user_byte(a, de) preserving %func
    inc de
    xor a
    call write_user_byte(a, de) preserving %func
    xor a
    ld l, a
    ld h, a
    jp bdos_ret


; F108: Get/Set Program Return Code
;   In: DE = 0xFFFF to get, else sets return_code = DE
;   Out: HL = return_code (get) or A = 0 (set)
;   Clobbers: AF, BC, DE, HL
; @proc bf_f108
; @param %param:u16 de
; @param %func:u8   c
; @out   a
; @out   hl
; @clobbers af,bc,de,hl
; @end
bf_f108:
    pop de
    pop bc
    ld a, d
    and e
    cp 0xFF                    ; DE == 0xFFFF?
    jr nz, .rc_set
    ; Get: return current return_code in HL
    ld hl, (return_code)
    ld a, l
    jp bdos_ret
.rc_set:
    ld (return_code), de
    xor a
    ld l, a
    ld h, a
    jp bdos_ret


; F109: Get/Set Console Mode
;   In: DE = 0xFFFF to get, else sets con_mode = DE
;   Out: HL = con_mode (get) or A = 0 (set)
;   Clobbers: AF, BC, DE, HL
; @proc bf_f109
; @param %param:u16 de
; @param %func:u8   c
; @out   a
; @out   hl
; @clobbers af,bc,de,hl
; @end
bf_f109:
    pop de
    pop bc
    ld a, d
    and e
    cp 0xFF                    ; DE == 0xFFFF?
    jr nz, .cm_set
    ld hl, (con_mode)
    ld a, l
    jp bdos_ret
.cm_set:
    ld (con_mode), de
    xor a
    ld l, a
    ld h, a
    jp bdos_ret


; F110: Get/Set Output Delimiter
;   In: E = 0xFF to get, else sets out_delim = E
;   Out: A = delimiter (get) or A = 0 (set)
;   Clobbers: AF, BC, DE, HL
; @proc bf_f110
; @param %param:u16 de
; @param %func:u8   c
; @out   a
; @out   hl
; @clobbers af,bc,de,hl
; @end
bf_f110:
    pop de
    pop bc
    ld a, e
    cp 0xFF
    jr nz, .dl_set
    ; Get current delimiter
    ld a, (out_delim)
    ld l, a
    ld h, 0
    jp bdos_ret
.dl_set:
    ld a, e
    ld (out_delim), a
    xor a
    ld l, a
    ld h, a
    jp bdos_ret


; F111: Print Block to Console
;   In: DE = pointer to CCB in TPA: [addr_lo, addr_hi, len_lo, len_hi]
;   Out: A = 0
;   Clobbers: AF, BC, DE, HL
; @proc bf_f111
; @param %ccb:u16   de
; @param %func:u8   c
; @out   a
; @out   hl
; @clobbers af,bc,de,hl
; @end
bf_f111:
    pop de
    pop bc
    ; Read CCB from TPA: [addr_lo, addr_hi, len_lo, len_hi]
    push de
    call read_user_byte(de) preserving %func    ; A = addr_lo
    ld c, a
    pop de
    inc de
    push de
    push bc                    ; lint: ignore — save C (addr_lo), B is don't-care
    call read_user_byte(de) preserving %func    ; A = addr_hi
    pop bc
    ld b, a                    ; BC = text address in TPA
    pop de
    inc de
    push de
    push bc                    ; Save BC (TPA addr) — read_user_byte clobbers BC
    call read_user_byte(de) preserving %func    ; A = len_lo
    pop bc
    ld l, a
    pop de
    inc de
    push de
    push bc
    call read_user_byte(de) preserving %func    ; A = len_hi
    pop bc
    ld h, a                    ; HL = length
    pop de
    ; BC = TPA address of text, HL = length
.pb_loop:
    ld a, h
    or l
    jr z, .pb_done
    push hl                    ; Save remaining length
    push bc                    ; Save TPA pointer
    ld d, b
    ld e, c                    ; DE = current TPA address
    call read_user_byte(de) preserving %func    ; A = char from TPA
    ld c, a
    call con_out               ; Output character
    pop bc
    inc bc                     ; Next TPA address
    pop hl
    dec hl                     ; Length--
    jr .pb_loop
.pb_done:
    xor a
    ld l, a
    ld h, a
    jp bdos_ret


; F112: List Block to Printer (stub, no printer)
;   Out: A = 0
;   Clobbers: AF, DE, BC, HL
; @proc bf_f112
; @param %param:u16 de
; @param %func:u8   c
; @out   a
; @out   hl
; @clobbers af,bc,de,hl
; @end
bf_f112:
    pop de
    pop bc
    xor a
    ld l, a
    ld h, a
    jp bdos_ret
