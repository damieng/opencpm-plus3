; @proc bf_f99
; @param %param:u16 de
; @param %func:u8   c
; @out   a
; @out   hl
; @clobbers af,bc,de,hl
; @end
bf_f99:
    pop de
    pop bc
    ld a, 0xFF
    ld l, a
    ld h, 0
    jp bdos_ret


